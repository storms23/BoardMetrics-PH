# ─── Supabase (Phase 2 checkpoint) ────────────────────────────────────────────
# Create a project at https://supabase.com, then Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Used by ETL + admin writes.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Scraper / OCR (Phase 3 checkpoint) ───────────────────────────────────────
# DeepSeek — primary OCR fallback (school tables + national stat images).
DEEPSEEK_API_KEY=your-deepseek-api-key
# DeepSeek chat API is text-only; image/PDF OCR uses OCR_SPACE_API_KEY (see scraper/ocr_llm.py).
OCR_SPACE_API_KEY=your-ocr-space-api-key

# Anthropic — deprecated; kept for backward compatibility only.
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Public API (Phase 8) ─────────────────────────────────────────────────────
# Comma-separated admin/partner API keys (optional, for higher rate limits).
ADMIN_API_KEYS=

# ─── Admin console (Phase 9) ──────────────────────────────────────────────────
# Password for the /admin console login. Leave empty to disable admin.
ADMIN_PASSWORD=
