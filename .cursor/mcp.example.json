{
  "_comment": "Copy this file to .cursor/mcp.json and fill in YOUR_* placeholders. Never commit mcp.json with real tokens.",
  "_reload": "After editing: Ctrl+Shift+P → Developer: Reload Window",
  "_docs": {
    "context7": "https://context7.com/dashboard",
    "supabase_token": "https://supabase.com/dashboard/account/tokens",
    "github_pat": "https://github.com/settings/tokens",
    "vercel_mcp": "https://vercel.com/docs/agent-resources/vercel-mcp",
    "sentry_mcp": "https://mcp.sentry.dev — OAuth login when Cursor connects"
  },
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref=blhwagwquxeacewzgmwq"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "YOUR_SUPABASE_PERSONAL_ACCESS_TOKEN"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "YOUR_GITHUB_PAT"
      }
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "sentry": {
      "url": "https://mcp.sentry.dev/mcp"
    }
  }
}
